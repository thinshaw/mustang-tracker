# macOS
.DS_Store

# Secrets — Supabase keys, Anthropic API key (phase 2). Never commit these.
.env
.env.*
!.env.example

# Real student data must never enter git. Grades live in Supabase only.
# Any local export/backup goes here and stays out of the repo.
/private/
*.local.csv

# Supabase CLI local link state (machine-specific, includes pooler URL)
supabase/.temp/

# Throwaway session used for local end-to-end testing. Never commit — it is a
# live bearer token.
_session.json

# Node (only if a tool step is ever added)
node_modules/
